{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "productName": "TareasZen",
  "mainBinaryName": "TareasZen",
  "version": "1.1.1",
  "identifier": "com.tareaszen.app",
  "plugins": {},
  "app": {
    "windows": [
      {
        "shadow": false,
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "TareasZen",
        "width": 1200,
        "minWidth": 800,
        "minHeight": 600,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  }
}